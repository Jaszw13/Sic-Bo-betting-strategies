    ax.set_xlim(-1000, target_capital + 1000) # Set x-limits to better show bankruptcy and target
    ax.tick_params(axis='both', which='major', labelsize=7)
    ax.legend(loc='upper right', fontsize=7)

plt.tight_layout(rect=[0, 0.03, 1, 0.98])
plt.show()

# Success vs. Bankruptcy Rates by Strategy and Minimum Bet
plot_df = quantified_results_df.melt(id_vars=['Strategy', 'Min Bet'],
                                     value_vars=['Probability of Reaching Target', 'Probability of Bankruptcy'],
                                     var_name='Metric',
                                     value_name='Probability')

plot_df['Strategy_MinBet'] = plot_df['Strategy'] + ' (Min Bet: ' + plot_df['Min Bet'].astype(str) + ')'

plt.figure(figsize=(10, 6))
sns.barplot(x='Strategy_MinBet', y='Probability', hue='Metric', data=plot_df, palette='viridis')

plt.title('Success vs. Bankruptcy Rates by Strategy and Minimum Bet', fontsize=14)
plt.xlabel('Strategy and Minimum Bet', fontsize=12)
plt.ylabel('Probability', fontsize=12)
plt.xticks(rotation=45, ha='right')
plt.ylim(0, 1)
plt.legend(title='Outcome', bbox_to_anchor=(1.05, 1), loc='upper left')
plt.tight_layout()
plt.show()
