# Populate 'Big' and 'Small' bet details based on standard Sic Bo rules
# There are 216 total outcomes (6^3)
# Winning outcomes for Small (4-10, excluding triples): 105 outcomes
# Winning outcomes for Big (11-17, excluding triples): 105 outcomes
# For simplicity, standard payout is 1:1 for Big/Small

small_prob = 105 / 216 # Probability of winning Small bet
big_prob = 105 / 216   # Probability of winning Big bet
payout_ratio_big_small = 1 # 1:1 payout

house_edge_small = (1 - (payout_ratio_big_small * small_prob)) * 100
house_edge_big = (1 - (payout_ratio_big_small * big_prob)) * 100

sic_bo_bets_df.loc[sic_bo_bets_df['Bet Type'] == 'Small', 'Probability of Winning'] = small_prob
sic_bo_bets_df.loc[sic_bo_bets_df['Bet Type'] == 'Small', 'Payout Ratio'] = payout_ratio_big_small
sic_bo_bets_df.loc[sic_bo_bets_df['Bet Type'] == 'Small', 'House Edge (%)'] = house_edge_small

sic_bo_bets_df.loc[sic_bo_bets_df['Bet Type'] == 'Big', 'Probability of Winning'] = big_prob
sic_bo_bets_df.loc[sic_bo_bets_df['Bet Type'] == 'Big', 'Payout Ratio'] = payout_ratio_big_small
sic_bo_bets_df.loc[sic_bo_bets_df['Bet Type'] == 'Big', 'House Edge (%)'] = house_edge_big

# Ensure sic_bo_bets_df has the correct types for payout ratio (from cell b6986481)
if pd.api.types.is_object_dtype(sic_bo_bets_df['Payout Ratio']):
    sic_bo_bets_df['Payout Ratio'] = pd.to_numeric(sic_bo_bets_df['Payout Ratio'], errors='coerce')
    sic_bo_bets_df['Payout Ratio'] = sic_bo_bets_df['Payout Ratio'].fillna(1)

# --- 2. Develop and Implement Betting Strategies (from cell 4c050833) ---

def roll_dice():
    """Simulates rolling three standard six-sided dice."""
    return (random.randint(1, 6), random.randint(1, 6), random.randint(1, 6))

def check_win(bet_type, dice_results):
    """Checks if a given bet wins based on dice results, excluding triples for Big/Small."""
    d1, d2, d3 = dice_results
    total_sum = d1 + d2 + d3
    is_triple = (d1 == d2 == d3)

    if bet_type == 'Small':
        # Small bet wins if total is 4-10, and not a triple
        return (4 <= total_sum <= 10) and not is_triple
    elif bet_type == 'Big':
        # Big bet wins if total is 11-17, and not a triple
        return (11 <= total_sum <= 17) and not is_triple
    else:
        # Placeholder for other bet types if needed later
        raise ValueError(f"Unsupported bet type: {bet_type}")

def fixed_bet_strategy(initial_capital, target_capital, min_bet, max_bet, max_rounds, bet_type, sic_bo_bets_df_local):
    """Simulates a single run of the fixed-bet strategy.

    Args:
        initial_capital (int): Starting capital.
        target_capital (int): Capital to reach to win.
        min_bet (int): Minimum bet amount (fixed bet).
        max_bet (int): Maximum allowable bet (for clipping current_bet).
        max_rounds (int): Maximum number of rounds to play.
        bet_type (str): Type of bet ('Big' or 'Small').
        sic_bo_bets_df_local (pd.DataFrame): DataFrame containing bet details.

    Returns:
        tuple: (final_capital, rounds_played, capital_history)
    """
    current_capital = initial_capital
    current_bet = min_bet
    rounds_played = 0
    capital_history = [initial_capital]

    payout_ratio = sic_bo_bets_df_local.loc[sic_bo_bets_df_local['Bet Type'] == bet_type, 'Payout Ratio'].iloc[0]

    while 0 < current_capital < target_capital and rounds_played < max_rounds:
        rounds_played += 1

        # Ensure bet does not exceed current capital
        actual_bet = min(current_bet, current_capital)
        if actual_bet == 0:
            break # Cannot place a bet, essentially bankrupt

        current_capital -= actual_bet
        dice_results = roll_dice()

        if check_win(bet_type, dice_results):
            current_capital += actual_bet * (1 + payout_ratio)

        capital_history.append(current_capital)

    return current_capital, rounds_played, capital_history

def martingale_strategy(initial_capital, target_capital, min_bet, max_bet, max_rounds, bet_type, sic_bo_bets_df_local):
    """Simulates a single run of the Martingale strategy.

    Args:
        initial_capital (int): Starting capital.
        target_capital (int): Capital to reach to win.
        min_bet (int): Minimum bet amount (starting bet).
        max_bet (int): Maximum allowable bet.
        max_rounds (int): Maximum number of rounds to play.
        bet_type (str): Type of bet ('Big' or 'Small').
        sic_bo_bets_df_local (pd.DataFrame): DataFrame containing bet details.

    Returns:
        tuple: (final_capital, rounds_played, capital_history)
    """
    current_capital = initial_capital
    current_bet = min_bet
    rounds_played = 0
    capital_history = [initial_capital]

    payout_ratio = sic_bo_bets_df_local.loc[sic_bo_bets_df_local['Bet Type'] == bet_type, 'Payout Ratio'].iloc[0]

    while 0 < current_capital < target_capital and rounds_played < max_rounds:
        rounds_played += 1

        # Adjust current_bet for max_bet and available capital
        bet_to_place = min(current_bet, max_bet, current_capital)

        if bet_to_place <= 0: # Cannot place a bet, essentially bankrupt
            break

        current_capital -= bet_to_place
        dice_results = roll_dice()

        if check_win(bet_type, dice_results):
            current_capital += bet_to_place * (1 + payout_ratio)
            current_bet = min_bet # Reset bet on win
        else:
            current_bet *= 2 # Double bet on loss

        capital_history.append(current_capital)

    return current_capital, rounds_played, capital_history

# --- 3. Run Comprehensive Simulations (from cell b6986481) ---

# Define the simulation parameters
initial_capital = 3000
target_capital = 10000
max_bet = 99000
max_rounds = 10000  # A sufficiently large number
num_experiments = 500
bet_type = 'Big'    # Using 'Big' for initial testing as per instructions

# Create an empty list to store all simulation results
all_simulation_results = []

# Iterate through the two strategies
strategies = {
    'Fixed Bet': fixed_bet_strategy,
    'Martingale': martingale_strategy
}

# Loop through the two minimum bet amounts
min_bet_options = [30, 50]

for strategy_name, strategy_func in strategies.items():
    print(f"\nRunning simulations for {strategy_name} strategy...")
    for min_bet_amount in min_bet_options:
        print(f"  With minimum bet: {min_bet_amount}")
        # Run num_experiments simulations for each combination
        for i in range(num_experiments):
            final_capital, rounds_played, capital_history = strategy_func(
                initial_capital,
                target_capital,
                min_bet_amount,
                max_bet,
                max_rounds,
                bet_type,
                sic_bo_bets_df
            )

            # Store the results into a dictionary
            result = {
                'Strategy': strategy_name,
                'Min Bet': min_bet_amount,
                'Bet Type': bet_type,
                'Initial Capital': initial_capital,
                'Target Capital': target_capital,
                'Max Bet': max_bet,
                'Max Rounds': max_rounds,
                'Final Capital': final_capital,
                'Rounds Played': rounds_played,
                'Capital History': capital_history
            }
            all_simulation_results.append(result)

# Convert the list of dictionaries into a pandas DataFrame
simulation_results_df = pd.DataFrame(all_simulation_results)

# --- 4. Analyze and Quantify Results (from cell 8d20a215) ---

# Calculate the 'Outcome' for each simulation
simulation_results_df['Outcome'] = np.where(
    simulation_results_df['Final Capital'] >= simulation_results_df['Target Capital'], 'Reached Target',
    np.where(simulation_results_df['Final Capital'] == 0, 'Bankrupt', 'Max Rounds Reached'
    )
)

# Group the simulation_results_df by 'Strategy' and 'Min Bet' and quantify results
aggr_results = simulation_results_df.groupby(['Strategy', 'Min Bet']).apply(lambda x: pd.Series({
    'Expected Revenue': (x['Final Capital'] - x['Initial Capital']).mean(),
    'Probability of Reaching Target': (x['Outcome'] == 'Reached Target').sum() / num_experiments,
    'Probability of Bankruptcy': (x['Outcome'] == 'Bankrupt').sum() / num_experiments
}), include_groups=False).reset_index()

quantified_results_df = aggr_results

print("\nQuantified Simulation Results:")
display(quantified_results_df)

# --- 5. Visualize Simulation Outcomes (from cells 9c35da8f, 758c9b8c, 15467952) ---

# Capital Trajectories for Sample Simulation Runs
num_plots_per_combo = 5

# Get unique combinations of Strategy and Min Bet
strategy_min_bet_combos = simulation_results_df[['Strategy', 'Min Bet']].drop_duplicates().values

# Determine grid size for subplots dynamically
num_combos = len(strategy_min_bet_combos)
num_rows_traj = num_combos # Each combo gets its own row
num_cols_traj = num_plots_per_combo # Each column is a sample trajectory

fig1, axes1 = plt.subplots(num_rows_traj, num_cols_traj, figsize=(num_cols_traj * 4, num_rows_traj * 3), sharey=True)
fig1.suptitle('Capital Trajectories for Sample Simulation Runs', fontsize=16, y=1.02)

for i, (strategy, min_bet) in enumerate(strategy_min_bet_combos):
    combo_df = simulation_results_df[
        (simulation_results_df['Strategy'] == strategy) &
        (simulation_results_df['Min Bet'] == min_bet)
    ]

    sample_runs = combo_df.sample(n=min(num_plots_per_combo, len(combo_df)), random_state=42)

    for j, (idx, row) in enumerate(sample_runs.iterrows()):
        ax = axes1[i, j] if num_rows_traj > 1 else axes1[j] # Handle single row case
        ax.plot(row['Capital History'], lw=1.5)
        ax.axhline(y=initial_capital, color='grey', linestyle='--', label='Initial Capital')
        ax.axhline(y=target_capital, color='green', linestyle='--', label='Target Capital')
        ax.axhline(y=0, color='red', linestyle='--', label='Bankruptcy')

        ax.set_title(f'{strategy} (Min Bet: {min_bet}) - Run {j+1}', fontsize=9)
        ax.set_xlabel('Rounds', fontsize=8)
        if j == 0:
            ax.set_ylabel('Capital', fontsize=8)

        if j == 0:
            ax.legend(loc='lower left', fontsize=7)

        ax.tick_params(axis='both', which='major', labelsize=7)

plt.tight_layout(rect=[0, 0.03, 1, 0.98])
plt.show()

# Distribution of Final Capitals
num_rows_dist = num_combos # Each combo gets its own row
num_cols_dist = 1 # One column for histograms

fig2, axes2 = plt.subplots(num_rows_dist, num_cols_dist, figsize=(num_cols_dist * 6, num_rows_dist * 4))
fig2.suptitle('Distribution of Final Capitals', fontsize=16, y=1.02)

for i, (strategy, min_bet) in enumerate(strategy_min_bet_combos):
